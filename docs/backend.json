
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the STR mix Digital platform, including authors of blog posts and administrators.",
      "properties": {
        "id": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "role",
        "createdAt"
      ]
    },
    "SystemConfig": {
      "title": "SystemConfig",
      "type": "object",
      "description": "Global configuration settings for the entire platform.",
      "properties": {
        "maintenanceMode": {
          "type": "boolean"
        },
        "siteName": {
          "type": "string"
        },
        "contactEmail": {
          "type": "string",
          "format": "email"
        },
        "visitorCount": {
          "type": "number"
        }
      }
    },
    "MediaAsset": {
      "title": "MediaAsset",
      "type": "object",
      "description": "Represents an uploaded file in the media library.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string", "enum": ["image", "video", "doc"] },
        "size": { "type": "number" },
        "mimeType": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Category": {
      "title": "Category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["id", "name", "slug"]
    },
    "Tag": {
      "title": "Tag",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["id", "name", "slug"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "bodyHtml": { "type": "string" },
        "authorId": { "type": "string" },
        "categoryId": { "type": "string" },
        "tagIds": { "type": "array", "items": { "type": "string" } },
        "publishedAt": { "type": "string", "format": "date-time" },
        "metaTitle": { "type": "string" },
        "metaDescription": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "slug", "bodyHtml", "authorId", "categoryId", "publishedAt", "metaTitle", "metaDescription", "createdAt", "updatedAt"]
    },
    "Review": {
      "title": "Review",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorName": { "type": "string" },
        "authorEmail": { "type": "string", "format": "email" },
        "rating": { "type": "number" },
        "body": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "authorName", "authorEmail", "rating", "body", "status", "createdAt"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "subject", "body", "status", "createdAt"]
    },
    "TicketReply": {
      "title": "TicketReply",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ticketId": { "type": "string" },
        "body": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ticketId", "body", "authorId", "createdAt"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/settings/global",
        "definition": {
          "entityName": "SystemConfig",
          "schema": {
            "$ref": "#/backend/entities/SystemConfig"
          },
          "description": "Global application settings."
        }
      },
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Grants administrative privileges."
        }
      },
      {
        "path": "/media_library/{assetId}",
        "definition": {
          "entityName": "MediaAsset",
          "schema": {
            "$ref": "#/backend/entities/MediaAsset"
          },
          "description": "Metadata for uploaded media files."
        }
      },
      {
        "path": "/admin_posts/{postId}",
        "definition": {
          "entityName": "Post",
          "schema": {
            "$ref": "#/backend/entities/Post"
          },
          "description": "Management collection for blog posts."
        }
      },
      {
        "path": "/published_posts/{postId}",
        "definition": {
          "entityName": "Post",
          "schema": {
            "$ref": "#/backend/entities/Post"
          },
          "description": "Public blog posts."
        }
      },
      {
        "path": "/categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": {
            "$ref": "#/backend/entities/Category"
          },
          "description": "Blog categories."
        }
      },
      {
        "path": "/tags/{tagId}",
        "definition": {
          "entityName": "Tag",
          "schema": {
            "$ref": "#/backend/entities/Tag"
          },
          "description": "Blog tags."
        }
      },
      {
        "path": "/admin_reviews/{reviewId}",
        "definition": {
          "entityName": "Review",
          "schema": {
            "$ref": "#/backend/entities/Review"
          },
          "description": "Review moderation queue."
        }
      },
      {
        "path": "/published_reviews/{reviewId}",
        "definition": {
          "entityName": "Review",
          "schema": {
            "$ref": "#/backend/entities/Review"
          },
          "description": "Public approved reviews."
        }
      },
      {
        "path": "/support_tickets/{ticketId}",
        "definition": {
          "entityName": "SupportTicket",
          "schema": {
            "$ref": "#/backend/entities/SupportTicket"
          },
          "description": "Customer support tickets."
        }
      },
      {
        "path": "/support_tickets/{ticketId}/replies/{replyId}",
        "definition": {
          "entityName": "TicketReply",
          "schema": {
            "$ref": "#/backend/entities/TicketReply"
          },
          "description": "Ticket conversation thread."
        }
      }
    ],
    "reasoning": "Standardized industrial data architecture with a central media library to manage project photos and videos."
  }
}
