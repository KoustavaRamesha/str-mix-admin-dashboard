
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * STR mix Digital Security Rules
     * Last audited: 2026-04-13
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function adminRoleData() {
      return get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data;
    }

    function hasAdminRole() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
        && (
          adminRoleData().role == 'admin'
          || adminRoleData().role == 'super_admin'
        );
    }

    function isSuperAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
        && adminRoleData().role == 'super_admin';
    }

    function isAdmin() {
      return hasAdminRole();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Data Validation Helpers ---

    function isValidString(field, maxLen) {
      return field is string && field.size() > 0 && field.size() <= maxLen;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // --- Collection Rules ---

    // Global settings — only admins can read operational config
    match /settings/global {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    // Public stats — separate doc for anonymous visitor counting
    match /public_stats/counters {
      allow read: if true;
      allow write: if true;
    }

    // Public maintenance flag — readable by everyone, writable by admins
    match /public_stats/maintenance {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public site content — readable by everyone, editable by admins
    match /public_content/site {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /media_library/{assetId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /admin_posts/{postId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /published_posts/{postId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /tags/{tagId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Reviews submitted by public users — validated on create
    match /admin_reviews/{reviewId} {
      allow get, list: if isAdmin();
      allow create: if
        hasRequiredFields(['authorName', 'professionalRole', 'body', 'rating', 'status', 'createdAt'])
        && isValidString(request.resource.data.authorName, 100)
        && isValidString(request.resource.data.professionalRole, 100)
        && isValidString(request.resource.data.body, 5000)
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    match /published_reviews/{reviewId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /projects/{projectId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // Support tickets — validated on create
    match /support_tickets/{ticketId} {
      allow create: if
        hasRequiredFields(['name', 'email', 'subject', 'body', 'status', 'createdAt'])
        && isValidString(request.resource.data.name, 100)
        && isValidString(request.resource.data.email, 254)
        && isValidString(request.resource.data.subject, 200)
        && isValidString(request.resource.data.body, 5000)
        && request.resource.data.status == 'open';
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.submittedById == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.submittedById == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /support_tickets/{ticketId}/replies/{replyId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.ticketSubmittedById == request.auth.uid);
      allow create: if isAdmin()
        && hasRequiredFields(['ticketId', 'body', 'authorId', 'authorName', 'createdAt'])
        && isValidString(request.resource.data.body, 5000);
      allow update, delete: if isAdmin();
    }
  }
}
