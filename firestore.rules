
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * STR mix Digital Security Rules
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && request.resource.data.id == userId;
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /admin_posts/{postId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /published_posts/{postId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /tags/{tagId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /admin_reviews/{reviewId} {
      allow get, list: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /published_reviews/{reviewId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow create: if true;
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.submittedById == request.auth.uid);
      allow update: if isAdmin() || (isSignedIn() && resource.data.submittedById == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /support_tickets/{ticketId}/replies/{replyId} {
      allow get, list: if isAdmin() || (isSignedIn() && resource.data.ticketSubmittedById == request.auth.uid);
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.ticketSubmittedById == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
